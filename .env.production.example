# =============================================================================
# AG-VOTE — Configuration PRODUCTION
# =============================================================================
# Copier ce fichier sur le serveur et adapter TOUTES les valeurs marquées <…>.
# Ne JAMAIS committer ce fichier avec de vrais secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=0
APP_SECRET=<generer-avec-php -r "echo bin2hex(random_bytes(32));">
APP_URL=https://<votre-domaine.fr>

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
DB_DSN=pgsql:host=<db-host>;port=5432;dbname=vote_app;sslmode=require
DB_USER=vote_app
DB_PASS=<mot-de-passe-fort-64-caracteres>

# -----------------------------------------------------------------------------
# Multi-tenant
# -----------------------------------------------------------------------------
DEFAULT_TENANT_ID=<uuid-de-votre-organisation>

# -----------------------------------------------------------------------------
# Clés API (optionnel — accès programmatique par rôle)
# Laisser vide pour désactiver l'accès par clé API.
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
# -----------------------------------------------------------------------------
API_KEY_OPERATOR=
API_KEY_TRUST=
API_KEY_ADMIN=

# -----------------------------------------------------------------------------
# Sécurité (les 3 DOIVENT être à 1)
# -----------------------------------------------------------------------------
APP_AUTH_ENABLED=1
CSRF_ENABLED=1
RATE_LIMIT_ENABLED=1

# Donnees de seed (DOIT etre a 0)
LOAD_SEED_DATA=0

# Authentification — tentatives de connexion
APP_LOGIN_MAX_ATTEMPTS=5
APP_LOGIN_WINDOW=300

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://<votre-domaine.fr>

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
MAIL_HOST=<smtp.votre-provider.com>
MAIL_PORT=587
MAIL_USER=<utilisateur-smtp>
MAIL_PASS=<mot-de-passe-smtp>
MAIL_FROM=noreply@<votre-domaine.fr>
MAIL_FROM_NAME="AG-VOTE"
MAIL_TLS=starttls
MAIL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<mot-de-passe-redis-fort-64-caracteres>
REDIS_DATABASE=0
REDIS_PREFIX=agvote:

# -----------------------------------------------------------------------------
# Push / SSE (Server-Sent Events) temps réel
# -----------------------------------------------------------------------------
PUSH_ENABLED=1

# -----------------------------------------------------------------------------
# Hardening v2.1 — sécurité périmétrique
# -----------------------------------------------------------------------------
# Adresses IP des reverse-proxies/load balancers TLS qui terminent la
# connexion devant l'app. Sans ça, un client malveillant peut spoofer
# X-Forwarded-For pour contourner le rate-limit du login. Liste CSV.
# Voir HARDEN-F02 dans SECURITY_AUDIT.md.
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# Hôtes (FQDN exacts) que MonitoringService::sendWebhook a le droit de
# contacter. Sans liste blanche, le webhook est silencieusement refusé
# pour bloquer SSRF / cloud metadata. Voir HARDEN-F11.
# MONITOR_WEBHOOK_ALLOWED_HOSTS=hooks.slack.com,monitoring.example.com

# Hôtes supplémentaires que /api/v1/email_redirect.php a le droit de
# rediriger vers (l'hôte dérivé d'APP_URL est toujours autorisé).
# Voir HARDEN-F11.
# EMAIL_REDIRECT_ALLOWED_HOSTS=app.example.com

# Strict (default) | Lax | None — politique SameSite des cookies de
# session. Default Strict bloque tout CSRF résiduel cross-site. Mettre
# Lax UNIQUEMENT si un flux suit un redirect tiers (ex: lien d'invitation
# vote depuis un email reçu dans une autre fenêtre). Voir HARDEN-F18.
# SESSION_COOKIE_SAMESITE=Strict

# 1 = promote la CSP nonce-based de Report-Only à enforcing. À activer
# UNIQUEMENT après avoir validé sur du trafic réel que zéro violation
# Report-Only n'apparaît dans les logs CSP. Voir HARDEN-F17.
# CSP_STRICT_MODE=1

# -----------------------------------------------------------------------------
# Monitoring & Alerting (optionnel)
# -----------------------------------------------------------------------------
# MONITOR_ALERT_EMAILS=ops@votre-domaine.fr
# MONITOR_ALERT_EMAILS=ops@example.com,admin@example.com
# MONITOR_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# MONITOR_AUTH_FAILURES_THRESHOLD=5
# MONITOR_DB_LATENCY_MS=2000
# MONITOR_DISK_FREE_PCT=10
# MONITOR_EMAIL_BACKLOG=100

# -----------------------------------------------------------------------------
# Fonctionnalités
# -----------------------------------------------------------------------------
EMAIL_TRACKING_ENABLED=0
PROXY_MAX_PER_RECEIVER=3

# -----------------------------------------------------------------------------
# Stockage
# Répertoire de travail : /tmp/ag-vote (créé par le Dockerfile)
# -----------------------------------------------------------------------------
AGVOTE_UPLOAD_DIR=/var/agvote/uploads

# Pour auditer votre configuration : php bin/validate-env
