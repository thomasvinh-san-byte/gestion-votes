# =============================================================================
# AG-VOTE — Configuration
# =============================================================================
# Copiez ce fichier vers .env et adaptez les valeurs.
# JAMAIS de secrets en dur dans le code !
#
# Pour un déploiement PRODUCTION, voir la section [PRODUCTION] ci-dessous.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Valeurs acceptées pour APP_ENV : development | demo | production
# Par défaut en mode démo : navigation libre sans authentification
APP_ENV=demo
APP_DEBUG=1
APP_SECRET=dev-secret-do-not-use-in-production-change-me-now-please-64chr

# [PRODUCTION] Décommentez et adaptez :
# APP_ENV=production
# APP_DEBUG=0
# APP_SECRET=   ← générer avec: php -r "echo bin2hex(random_bytes(32));"

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# OBLIGATOIRE : DB_PASS doit être défini (docker-compose échouera sinon)
# Utilisez un utilisateur dédié (ne pas utiliser 'postgres' en production)
# Exécuter: database/setup.sh pour créer l'utilisateur et la base
# -----------------------------------------------------------------------------
DB_DSN=pgsql:host=localhost;port=5432;dbname=vote_app
DB_USER=vote_app
DB_PASS=vote_app_dev_2026

# [PRODUCTION] Ajouter sslmode=require pour les connexions cloud :
# DB_DSN=pgsql:host=<host>;port=5432;dbname=vote_app;sslmode=require

# -----------------------------------------------------------------------------
# Multi-tenant
# -----------------------------------------------------------------------------
DEFAULT_TENANT_ID=aaaaaaaa-1111-2222-3333-444444444444

# [PRODUCTION] Remplacez par l'UUID de votre organisation :
# DEFAULT_TENANT_ID=<votre-uuid>

# -----------------------------------------------------------------------------
# Sécurité
# -----------------------------------------------------------------------------
# Auth par email/mot de passe (sessions PHP). Mettre à 0 pour désactiver temporairement.
# IMPORTANT : les 3 DOIVENT être à 1 en production !
# En mode démo, auth/CSRF/rate-limit sont désactivés pour naviguer librement
APP_AUTH_ENABLED=0
CSRF_ENABLED=0
RATE_LIMIT_ENABLED=0

# NOTE: Le rate limiting est géré par nginx (voir deploy/nginx.conf).
# CSRF_LIFETIME, RATE_LIMIT_REQUESTS, RATE_LIMIT_PERIOD sont réservés
# pour une future version et ne sont pas encore lus par l'application.

# Données de démo (utilisateurs test, AG fictives)
# DOIT être à 0 en production !
LOAD_DEMO_DATA=1

# [PRODUCTION] :
# LOAD_DEMO_DATA=0

# -----------------------------------------------------------------------------
# CORS (origines autorisées, séparées par virgules)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# [PRODUCTION] :
# CORS_ALLOWED_ORIGINS=https://vote.mondomaine.fr

# -----------------------------------------------------------------------------
# Email (optionnel, pour envoi de rapports)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="AG-VOTE"

# -----------------------------------------------------------------------------
# Redis (queue, rate limiter, cache)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=agvote-redis-dev
REDIS_DATABASE=0
REDIS_PREFIX=agvote:

# [PRODUCTION] Remplacez par un mot de passe fort :
# REDIS_PASSWORD=<generated-64-char-password>

# -----------------------------------------------------------------------------
# Push / SSE (Server-Sent Events) temps réel
# -----------------------------------------------------------------------------
# Active le push temps réel (SSE). Si Redis est disponible, utilise Redis ;
# sinon, fallback automatique sur fichier (/tmp/agvote-sse-*.json).
# Mettre à 0 pour désactiver complètement le push (polling classique uniquement).
PUSH_ENABLED=1

# -----------------------------------------------------------------------------
# Monitoring & Alerting
# -----------------------------------------------------------------------------
# Alert email recipients: comma-separated emails, or "auto" to email all admin users.
# Set to empty or 0 to disable alert emails.
# MONITOR_ALERT_EMAILS=auto
# MONITOR_ALERT_EMAILS=ops@example.com,admin@example.com

# Webhook URL for alert notifications (Slack, PagerDuty, Datadog, etc.)
# MONITOR_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Alert thresholds (defaults shown)
# MONITOR_AUTH_FAILURES_THRESHOLD=5
# MONITOR_DB_LATENCY_MS=2000
# MONITOR_DISK_FREE_PCT=10
# MONITOR_EMAIL_BACKLOG=100

# -----------------------------------------------------------------------------
# Stockage & PDF — chemins en dur dans le code (non configurables pour l'instant)
# Répertoire de travail : /tmp/ag-vote (créé par le Dockerfile)
# -----------------------------------------------------------------------------
